<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>gn-math</title>
  <link href="https://cdn.jsdelivr.net/npm/remixicon@4.7.0/fonts/remixicon.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
  <style>
    /* ── Base / Theme Defaults ──────────────────────────────────────────── */
    :root {
      --bg: #0a0a0a;
      --secondary-bg: #1c1c1c;
      --third-bg: #333333;
      --fourth-bg: #121212;
      --primary: #ffffff;
      --secondary: #b0b0b0;
      --text-color: #ffffff;
      --secondary-text-color: #e0e0e0;
      --button-bg: #1c1c1c;
      --button-hover: #2b2b2b;
      --gradient-start: #ffffff;
      --gradient-end: #6c757d;
      --accent: var(--primary);
      --cb: 255, 255, 255;
      --bc: 0, 0, 0;
    }

    * {
      box-sizing: border-box;
      font-family: "Inter", sans-serif;
    }

    /* ── Body ───────────────────────────────────────────────────────────── */
    body {
      margin: 0;
      background-color: var(--bg);
      color: white;
      overflow: hidden;
      height: 100vh;
      width: 100vw;
    }

    /* ── Backdrop ───────────────────────────────────────────────────────── */
    .backdrop {
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background-color: rgba(var(--bc), 0);
      backdrop-filter: blur(0px);
      z-index: 10;
      pointer-events: none;
      transition: 0.2s ease;
    }
    .backdrop.active {
      background-color: rgba(var(--bc), 0.75);
      backdrop-filter: blur(10px);
      pointer-events: auto;
    }

    /* ── Top Bar ────────────────────────────────────────────────────────── */
    .top-bar-container {
      position: fixed;
      top: 10px; left: 0; right: 0;
      padding: 0 12px;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      z-index: 20;
      pointer-events: none;
    }
    .top-bar-content {
      display: flex;
      align-items: flex-start;
      pointer-events: none;
      margin: auto;
    }
    .dropdown-wrapper {
      position: relative;
      pointer-events: auto;
      z-index: 21;
    }
    .search-bar,
    .dropdown-menu {
      display: flex;
      align-items: center;
      gap: 8px;
      height: 48px;
      padding: 0 12px;
      background-color: var(--fourth-bg);
      border-radius: 14px;
      border: 1.5px solid rgba(var(--cb), 0.08);
      pointer-events: auto;
      flex-shrink: 0;
    }
    .search-bar {
      width: 420px;
      margin: 0 12px;
      position: relative;
    }
    .dropdown-menu {
      width: 180px;
      cursor: pointer;
      transition: opacity 0.4s ease;
    }
    #source-dropdown-wrapper.searching-mode {
      pointer-events: none;
      opacity: 0.15;
    }
    .dropdown-menu .dropdown-text {
      flex: 1;
      font-size: 16px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      color: rgba(var(--cb), 0.7);
    }
    .dropdown-menu i,
    .search-bar i {
      color: rgba(var(--cb), 0.5);
      font-size: 24px;
    }
    .search-bar .filter-icon,
    .global-search-icon {
      cursor: pointer;
      transition: color 0.2s ease;
    }
    .global-search-icon.active {
      color: rgba(var(--cb)) !important;
    }

    /* ── Dropdowns ──────────────────────────────────────────────────────── */
    .dropdown-options {
      position: absolute;
      top: 100%;
      left: 0;
      width: auto;
      min-width: 100%;
      margin-top: 8px;
      background-color: var(--fourth-bg);
      border-radius: 14px;
      border: 1.5px solid rgba(var(--cb), 0.08);
      padding: 4px;
      box-sizing: border-box;
      opacity: 0;
      visibility: hidden;
      transform: scale(0.96);
      transition: 0.2s ease;
      z-index: 23;
      display: flex;
      gap: 4px;
    }
    .dropdown-wrapper.open .dropdown-options {
      opacity: 1;
      visibility: visible;
      transform: scale(1);
    }
    .dropdown-column {
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
      min-width: 170px;
    }
    .dropdown-options .option {
      padding: 12px;
      font-size: 16px;
      border-radius: 8px;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--text-color);
      transition: background-color 0.2s ease;
    }
    .dropdown-options .option i {
      font-size: 20px;
      color: rgba(var(--cb), 0.5);
    }
    .dropdown-options .option:hover {
      background-color: rgba(var(--cb), 0.08);
    }
    .dropdown-divider {
      height: 1px;
      background-color: rgba(var(--cb), 0.08);
      margin: 4px 8px;
      pointer-events: none;
    }
    .filter-dropdown { position: static; z-index: 998; }
    .filter-dropdown-options {
      top: 100%;
      margin-top: 8px;
      right: 0;
      left: auto;
      width: 180px !important;
      z-index: 999;
      display: block;
    }

    /* ── Search Input ───────────────────────────────────────────────────── */
    .search-bar input {
      flex: 1;
      height: 100%;
      background: transparent;
      border: none;
      outline: none;
      color: white;
      font-size: 16px;
      padding: 0;
    }
    .search-bar input::placeholder {
      color: rgba(var(--cb), 0.45);
      transition: opacity 0.2s ease;
    }
    .search-bar input:focus::placeholder { opacity: 0; }

    /* ── Grid ───────────────────────────────────────────────────────────── */
    .grid-container {
      margin-top: 64px;
      grid-template-columns: repeat(4, 220px);
      justify-content: center;
      gap: 12px;
      padding: 12px;
      padding-bottom: 100px;
      max-height: calc(100vh - 64px);
      overflow-y: auto;
      scrollbar-width: none;
      position: relative;
      box-sizing: border-box;
      display: grid;
    }
    .grid-container::-webkit-scrollbar { display: none; }
    .grid-container::before,
    .grid-container::after {
      content: "";
      position: fixed;
      left: 0; right: 0;
      width: 100%;
      z-index: 15;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.2s ease;
    }
    .grid-container::before {
      top: 58px;
      background: linear-gradient(to bottom, var(--bg) 10%, transparent);
      height: 60px;
    }
    .grid-container::after {
      bottom: 0;
      background: linear-gradient(to top, var(--bg) 10%, transparent);
      height: 100px;
    }
    .grid-container.show-top-mask::before { opacity: 1; }
    .grid-container.show-bottom-mask::after { opacity: 1; }

    #global-status-text {
      display: none;
      grid-column: 1 / -1;
      text-align: center;
      font-size: 14px;
      letter-spacing: 2px;
      color: rgba(var(--cb), 0.4);
      margin-bottom: 20px;
      font-weight: 600;
      text-transform: uppercase;
    }
    #global-status-text.visible { display: block; }

    .list-description {
      display: none;
      grid-column: 1 / -1;
      width: 460px;
      margin: 0 auto 12px auto;
      background-color: var(--fourth-bg);
      border-radius: 14px;
      border: 1.5px solid rgba(var(--cb), 0.08);
      padding: 12px 14px;
      color: rgba(var(--cb), 0.8);
      font-size: 15.5px;
      text-align: left;
      box-sizing: border-box;
      line-height: 1.2;
    }
    .no-results-message {
      display: none;
      text-align: center;
      font-size: 16px;
      color: rgba(var(--cb), 0.6);
      padding-top: 40px;
    }
    .games-divider,
    .no-results-message { grid-column: 1 / -1; }

    /* ── Loading State ──────────────────────────────────────────────────── */
    #grid-loading {
      display: none;
      grid-column: 1 / -1;
      text-align: center;
      padding: 60px 0;
      color: rgba(var(--cb), 0.35);
      font-size: 13px;
      letter-spacing: 2px;
      font-weight: 600;
      text-transform: uppercase;
    }
    #grid-loading.visible { display: block; }

    /* ── Cards ──────────────────────────────────────────────────────────── */
    .card {
      border-radius: 16px;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
      height: 175px;
      width: 220px;
      color: white;
      font-weight: 500;
      font-size: 14px;
      transition: transform 0.2s, background-color 0.2s, opacity 0.4s ease;
      position: relative;
      overflow: hidden;
      background-color: var(--fourth-bg);
      will-change: transform;
      flex-shrink: 0;
      cursor: pointer;
    }
    .grid-container.fade-games .card {
      opacity: 0.15;
      pointer-events: none;
    }
    .card::after {
      content: "";
      position: absolute;
      inset: 0;
      background-image: var(--bg-image);
      background-size: cover;
      background-position: center;
      opacity: 0;
      transition: opacity 0.8s ease;
      z-index: 0;
    }
    .card.loaded::after { opacity: 1; }
    .card::before {
      content: "";
      position: absolute;
      inset: 0;
      background-color: rgba(var(--bc), 0);
      backdrop-filter: blur(0px);
      transition: all 0.15s ease;
      z-index: 1;
      will-change: background-color, backdrop-filter;
    }
    .card:hover { transform: scale(1.03); }
    .card:hover::before {
      background-color: rgba(var(--bc), 0.4);
      backdrop-filter: blur(10px);
    }
    .card-name {
      margin: 0;
      padding: 12px;
      position: relative;
      z-index: 2;
      opacity: 0;
      transition: opacity 0.4s cubic-bezier(0.25, 0.8, 0.25, 1),
                  transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
      font-size: 24px;
      color: rgba(var(--cb));
    }
    .card-info-container {
      position: absolute;
      bottom: 12px;
      left: 12px;
      z-index: 2;
      display: flex;
      align-items: center;
      gap: 8px;
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .card-info-container i {
      font-size: 18px;
      color: rgba(var(--cb), 0.5);
    }
    .card-info-text {
      display: flex;
      flex-direction: column;
      line-height: 1.1;
    }
    .card-source-name {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.5px;
      color: rgba(var(--cb), 0.5);
      text-transform: uppercase;
    }
    .card-type {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 1px;
      color: rgba(var(--cb), 0.4);
    }
    .card.no-image-style:not(:hover) .card-name {
      color: rgba(var(--cb), 0.85) !important;
      opacity: 1 !important;
    }
    .card.no-image-style:not(:hover) .card-info-container { display: none !important; }
    .card:hover .card-name,
    .card:hover .card-info-container { opacity: 1; }
    .card.featured .card-name { font-weight: bold; }

    .games-divider {
      width: 100%;
      height: 1.5px;
      background-color: rgba(var(--cb), 0.05);
      border-radius: 5px;
      margin: 8px 0;
    }

    /* ── View Transitions ───────────────────────────────────────────────── */
    #browser-view,
    #game-overlay {
      transition: opacity 0.3s ease, transform 0.3s ease;
      will-change: opacity, transform;
    }
    #browser-view {
      height: 100vh;
      width: 100vw;
      display: flex;
      flex-direction: column;
      opacity: 1;
      transform: scale(1);
    }
    #browser-view.view-hidden {
      opacity: 0;
      transform: scale(0.98);
      pointer-events: none;
    }
    #game-overlay {
      position: fixed;
      inset: 0;
      background-color: var(--bg);
      z-index: 1000;
      display: none;
      opacity: 0;
      transform: translateY(10px);
    }
    #game-overlay.view-active {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Game Layout ────────────────────────────────────────────────────── */
    #game-wrapper {
      display: flex;
      height: 100%;
      width: 100%;
      align-items: flex-start;
    }
    #button-panel {
      display: none;
      flex-direction: column;
      gap: 10px;
      width: 68px;
      padding: 10px;
      box-sizing: border-box;
    }
    .icon-button {
      width: 48px;
      height: 48px;
      color: var(--text-color);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      transition: all 0.2s ease;
      border-radius: 16px;
      background-color: var(--fourth-bg);
      backdrop-filter: blur(12px);
      border: 1.5px solid rgba(var(--cb), 0.1);
    }
    .icon-button:hover {
      background-color: rgba(var(--cb), 0.08);
      border-color: rgba(var(--cb), 0.15);
    }
    .icon-button:active { transform: scale(0.95); }
    #game-content-frame {
      display: none;
      opacity: 0;
      transition: opacity 0.4s ease;
      border: none;
      box-sizing: border-box;
      border-radius: 16px;
      height: calc(100% - 20px);
      width: calc(100% - 68px - 10px);
      margin: 10px;
      margin-left: 0;
      background-color: #000;
      outline: none;
    }

    /* ── Loading ────────────────────────────────────────────────────────── */
    #loading-container {
      display: none;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
      color: var(--text-color);
    }
    .lds-ripple {
      display: inline-block;
      position: relative;
      width: 80px;
      height: 80px;
    }
    .lds-ripple div {
      position: absolute;
      inset: 0;
      margin: auto;
      border: 4px solid currentColor;
      border-radius: 50%;
      box-sizing: border-box;
      opacity: 0;
      animation: lds-ripple 1.4s cubic-bezier(0, 0.2, 0.8, 1) infinite;
    }
    .lds-ripple div:nth-child(2) { animation-delay: -0.7s; }
    @keyframes lds-ripple {
      0%   { transform: scale(0); opacity: 0; }
      6%   { transform: scale(0.02); opacity: 1; }
      100% { transform: scale(1); opacity: 0; }
    }
    #loading-message {
      font-size: 16px;
      margin-top: 12px;
      opacity: 0.7;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    /* ── Animations ─────────────────────────────────────────────────────── */
    .fade-slide-in { animation: fadeSlideIn 0.28s forwards; }
    .fade-slide-out { animation: fadeSlideOut 0.18s forwards; }
    @keyframes fadeSlideIn {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 0.7; transform: translateY(0); }
    }
    @keyframes fadeSlideOut {
      from { opacity: 0.7; transform: translateY(0); }
      to   { opacity: 0; transform: translateY(10px); }
    }
    .fade-out { animation: loaderFadeOut 0.4s forwards; }
    @keyframes loaderFadeOut {
      from { opacity: 1; }
      to   { opacity: 0; }
    }

    /* ── Responsive ─────────────────────────────────────────────────────── */
    @media (max-width: 1000px) {
      .grid-container { grid-template-columns: repeat(3, 220px); }
    }
    @media (max-width: 750px) {
      .grid-container { grid-template-columns: repeat(2, 220px); }
      .top-bar-container {
        top: 0;
        padding: 10px 12px;
        background-color: var(--bg);
        z-index: 30;
        align-items: center;
      }
      .top-bar-content {
        pointer-events: auto;
        flex-direction: row;
        flex-wrap: wrap;
        max-width: 100%;
        justify-content: space-between;
        margin: 0;
      }
      .search-bar {
        width: 100%;
        margin: 0 0 10px 0;
        order: 1;
        flex-basis: 100%;
      }
      #source-dropdown-wrapper { width: 100%; margin-bottom: 10px; order: 2; }
      .dropdown-menu { width: 100%; }
      .dropdown-options { left: 0; right: 0; width: 100%; flex-direction: column; }
      .dropdown-column { min-width: 100%; }
      .list-description { width: 100%; }
      .grid-container {
        grid-template-columns: repeat(2, 1fr);
        max-width: 100%;
        margin-top: 0;
        padding-top: 135px;
      }
      .card { width: 100%; height: 120px; transform: none !important; }
      .card:hover { transform: none; }
      .card::before {
        background-color: rgba(var(--bc), 0.4);
        backdrop-filter: blur(10px);
        display: block;
      }
      .card-name { opacity: 1; font-size: 20px; }
      #game-wrapper { flex-direction: column; align-items: stretch; }
      #button-panel {
        display: none;
        flex-direction: row;
        justify-content: flex-end;
        width: 100%;
        height: 68px;
        padding: 10px;
        flex-shrink: 0;
        order: 2;
      }
      #game-content-frame {
        width: 100%;
        height: calc(100% - 68px);
        margin: 0;
        border-radius: 0;
        order: 1;
      }
    }
    @media (max-width: 450px) {
      .grid-container {
        grid-template-columns: 1fr;
        padding-left: 12px;
        padding-right: 12px;
      }
    }
  </style>
</head>
<body>

  <!-- ── Browser View ─────────────────────────────────────────────────── -->
  <div id="browser-view">
    <div class="backdrop" id="backdrop"></div>

    <div class="top-bar-container">
      <div class="top-bar-content">

        <!-- Source Dropdown -->
        <div class="dropdown-wrapper" id="source-dropdown-wrapper">
          <div class="dropdown-menu" id="source-selector">
            <i class="ri-calculator-line" id="current-source-icon"></i>
            <span class="dropdown-text">gn-math</span>
            <i class="ri-arrow-down-s-line" id="source-chevron"></i>
          </div>
          <div class="dropdown-options" id="source-options-container"></div>
        </div>

        <!-- Search Bar -->
        <div class="search-bar">
          <i class="ri-search-line"></i>
          <input type="text" placeholder="Search gn-math...">
          <i class="ri-global-line global-search-icon" id="global-search-btn" title="Search all sources"></i>
          <div class="dropdown-wrapper filter-dropdown" id="filter-dropdown-wrapper">
            <i class="ri-filter-3-line filter-icon"></i>
            <div class="dropdown-options filter-dropdown-options">
              <div class="option" data-value="default">Default</div>
              <div class="option" data-value="alphabetical">Alphabetical</div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- Game Grid -->
    <div class="grid-container show-bottom-mask show-top-mask" id="grid">
      <div id="global-status-text">SEARCHING ALL SOURCES...</div>
      <div id="list-description" class="list-description" style="display:none;"></div>
      <div id="grid-loading">LOADING GAMES...</div>
      <p class="no-results-message" style="display:none;">No results found.</p>
    </div>
  </div>

  <!-- ── Game Overlay ─────────────────────────────────────────────────── -->
  <div id="game-overlay" style="display:none;">
    <div id="loading-container" style="display:none;" class="fade-out">
      <div class="lds-ripple"><div></div><div></div></div>
      <div id="loading-message">LOADING..</div>
    </div>
    <div id="game-wrapper">
      <div id="button-panel" style="display:none;">
        <button class="icon-button" id="back-btn" title="Back">
          <i class="ri-arrow-left-line"></i>
        </button>
        <button class="icon-button" id="fullscreen-btn" title="Fullscreen">
          <i class="ri-fullscreen-line"></i>
        </button>
      </div>
      <iframe id="game-content-frame" tabindex="1" src="about:blank" style="display:none; opacity:0;"></iframe>
    </div>
  </div>

  <script>
    // ── CDN Base URLs ─────────────────────────────────────────────────────
    const COVER_URL = "https://cdn.jsdelivr.net/gh/gn-math/covers@main";
    const HTML_URL  = "https://cdn.jsdelivr.net/gh/gn-math/html@main";
    const ZONES_URL = "https://cdn.jsdelivr.net/gh/gn-math/assets@main/zones.json";

    // ── Source definition (filled after fetch) ────────────────────────────
    const GAME_LISTS = [
      {
        Name: "gn-math",
        Icon: "ri-calculator-line",
        Type: "local",
        games: []   // populated by fetchGames()
      }
    ];

    // ── Globals ───────────────────────────────────────────────────────────
    const browserView   = document.getElementById("browser-view");
    const grid          = document.getElementById("grid");
    const noResults     = document.querySelector(".no-results-message");
    const listDesc      = document.getElementById("list-description");
    const gridLoading   = document.getElementById("grid-loading");
    const dropdowns     = document.querySelectorAll(".dropdown-wrapper");
    const gameOverlay   = document.getElementById("game-overlay");
    const srcWrapper    = document.getElementById("source-dropdown-wrapper");
    const srcContainer  = document.getElementById("source-options-container");
    const srcText       = srcWrapper.querySelector(".dropdown-menu .dropdown-text");
    const srcIcon       = document.getElementById("current-source-icon");
    const searchBar     = document.querySelector(".search-bar");
    const input         = searchBar.querySelector("input");
    const filterIcon    = document.querySelector(".filter-icon");
    const filterWrapper = document.getElementById("filter-dropdown-wrapper");
    const backdrop      = document.getElementById("backdrop");
    const iframe        = document.getElementById("game-content-frame");
    const loadingCont   = document.getElementById("loading-container");
    const loadingMsg    = document.getElementById("loading-message");
    const btnPanel      = document.getElementById("button-panel");
    const fullscreenBtn = document.getElementById("fullscreen-btn");
    const backBtn       = document.getElementById("back-btn");
    const globalBtn     = document.getElementById("global-search-btn");
    const globalStatus  = document.getElementById("global-status-text");

    let currentFilteredList = [];
    let renderedCount = 0;
    const BATCH_SIZE = 50;
    const sentinel = document.createElement("div");
    sentinel.style.cssText = "height:20px;width:100%;";

    let imageObserver, scrollObserver;
    let currentSource = null;
    let currentFilter = "default";
    let allGames = [];
    let switchTextTimeout;
    let isGlobalSearch = false;
    let debounceTimer;

    const GRADIENT_PALETTE = Array.from({ length: 20 }, (_, i) => {
      const h = Math.floor((360 / 20) * i);
      return `linear-gradient(135deg,hsl(${h},55%,65%),hsl(${(h+40)%360},55%,55%))`;
    });
    const randomBg = () => GRADIENT_PALETTE[Math.floor(Math.random() * GRADIENT_PALETTE.length)];

    // ── URL placeholder replacement ───────────────────────────────────────
    function resolveUrl(url) {
      if (!url) return "";
      return url
        .replace(/\{COVER_URL\}/g, COVER_URL)
        .replace(/\{HTML_URL\}/g,  HTML_URL);
    }

    // ── Fetch games from CDN (FROGIEE.ONE pattern: cache-bust with ?t=) ──
    async function fetchGames() {
      gridLoading.classList.add("visible");
      try {
        const res  = await fetch(ZONES_URL + "?t=" + Date.now());
        const data = await res.json();

        GAME_LISTS[0].games = data
          .filter(g => g.id !== -1)   // exclude the Discord "suggest games" entry
          .map(g => ({
            name:       g.name,
            cover:      resolveUrl(g.cover),
            url:        resolveUrl(g.url),
            featured:   !!g.featured,
            special:    g.special || [],
            author:     g.author     || "",
            authorLink: g.authorLink || ""
          }));
      } catch (err) {
        console.error("Failed to fetch zones.json:", err);
        gridLoading.textContent = "FAILED TO LOAD GAMES";
        return;
      }
      gridLoading.classList.remove("visible");
      initSource();
    }

    // ── Search ────────────────────────────────────────────────────────────
    function runSearchDebounced() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(filterSortGames, isGlobalSearch ? 400 : 250);
    }

    function setPlaceholder() {
      input.placeholder = isGlobalSearch
        ? "Search all sources..."
        : `Search ${currentSource ? currentSource.Name : "games"}...`;
    }

    function handleScrollMasks() {
      grid.classList.toggle("show-top-mask", grid.scrollTop > 10);
      const atBottom = grid.scrollHeight - grid.scrollTop <= grid.clientHeight + 10;
      grid.classList.toggle("show-bottom-mask", !atBottom && grid.scrollHeight > grid.clientHeight);
    }

    function performGlobalSearch() {
      const q = input.value.toLowerCase();
      if (!q) { clearGrid(); noResults.style.display = "none"; return; }

      globalStatus.classList.add("visible");
      grid.classList.add("fade-games");

      let combined = [];
      GAME_LISTS.forEach(source => {
        source.games
          .filter(g => g.name.toLowerCase().includes(q))
          .forEach(g => combined.push({ ...g, sourceName: source.Name, sourceIcon: source.Icon }));
      });

      // Dedupe
      const seen = new Set();
      combined = combined.filter(item => {
        const id = `${item.name}-${item.url}`;
        return seen.has(id) ? false : seen.add(id);
      });

      if (currentFilter === "alphabetical") combined.sort((a,b) => a.name.localeCompare(b.name));

      currentFilteredList = combined;
      clearGrid();
      noResults.style.display = combined.length === 0 ? "block" : "none";
      renderNextBatch();
      globalStatus.classList.remove("visible");
      grid.classList.remove("fade-games");
      handleScrollMasks();
    }

    function clearGrid() {
      renderedCount = 0;
      grid.querySelectorAll(".card, .games-divider, #sentinel-marker").forEach(el => el.remove());
    }

    function filterSortGames() {
      if (isGlobalSearch) { performGlobalSearch(); return; }

      const q = input.value.toLowerCase();
      let filtered = allGames.filter(g => g.name.toLowerCase().includes(q));

      if (currentFilter === "alphabetical") {
        filtered.sort((a,b) => a.name.localeCompare(b.name));
        currentFilteredList = filtered;
      } else {
        const featured = filtered.filter(g => g.featured);
        const regular  = filtered.filter(g => !g.featured);
        currentFilteredList = [...featured];
        if (featured.length && regular.length) currentFilteredList.push({ isDivider: true });
        currentFilteredList.push(...regular);
      }

      clearGrid();
      noResults.style.display = filtered.length === 0 && q ? "block" : "none";
      renderNextBatch();
      handleScrollMasks();
    }

    // ── Image Loading ─────────────────────────────────────────────────────
    function loadImage(card) {
      if (card.classList.contains("loaded")) return;
      const url = card.dataset.src;
      if (!url) { card.style.setProperty("--bg-image", randomBg()); card.classList.add("no-image-style","loaded"); return; }
      const img = new Image();
      img.onload  = () => { card.style.setProperty("--bg-image",`url('${url}')`); card.classList.remove("no-image-style"); card.classList.add("loaded"); };
      img.onerror = () => { card.style.setProperty("--bg-image", randomBg()); card.classList.add("no-image-style","loaded"); };
      img.src = url;
    }

    function setupObservers() {
      imageObserver = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { loadImage(e.target); imageObserver.unobserve(e.target); } });
      }, { root: grid, rootMargin: "200px" });

      scrollObserver = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) renderNextBatch();
      }, { root: grid, rootMargin: "600px" });
    }

    // ── Card Creation ─────────────────────────────────────────────────────
    function getCardTypeLabel(game) {
      if (game.special && game.special.length) {
        // Show first special tag in uppercase
        return game.special[0].toUpperCase();
      }
      return "GAME";
    }

    function createCard(game) {
      const card = document.createElement("div");
      card.className = game.featured ? "card featured" : "card";

      const nameEl = document.createElement("div");
      nameEl.className = "card-name";
      nameEl.textContent = game.name;
      card.appendChild(nameEl);

      const info = document.createElement("div");
      info.className = "card-info-container";

      const ico = document.createElement("i");
      ico.className = game.sourceIcon || srcIcon.className;
      info.appendChild(ico);

      const txt = document.createElement("div");
      txt.className = "card-info-text";

      if (isGlobalSearch && game.sourceName) {
        const sl = document.createElement("div");
        sl.className = "card-source-name";
        sl.textContent = game.sourceName;
        txt.appendChild(sl);
      } else {
        const tl = document.createElement("div");
        tl.className = "card-type";
        tl.textContent = getCardTypeLabel(game);
        txt.appendChild(tl);
      }
      info.appendChild(txt);
      card.appendChild(info);

      if (game.cover) card.dataset.src = game.cover;

      card.addEventListener("click", () => playGame(game.url, game.name));
      return card;
    }

    function renderNextBatch() {
      if (renderedCount >= currentFilteredList.length) return;
      const frag = document.createDocumentFragment();
      currentFilteredList.slice(renderedCount, renderedCount + BATCH_SIZE).forEach(item => {
        if (item.isDivider) {
          const d = document.createElement("div"); d.className = "games-divider"; frag.appendChild(d);
        } else {
          const card = createCard(item); frag.appendChild(card); imageObserver.observe(card);
        }
      });
      sentinel.remove();
      grid.appendChild(frag);
      renderedCount += Math.min(BATCH_SIZE, currentFilteredList.length - renderedCount);
      if (renderedCount < currentFilteredList.length) {
        sentinel.id = "sentinel-marker"; grid.appendChild(sentinel); scrollObserver.observe(sentinel);
      }
    }

    // ── Source Loading ────────────────────────────────────────────────────
    function loadSource(source) {
      currentSource = source;
      srcText.textContent = source.Name;
      srcIcon.className = source.Icon || "ri-file-line";
      input.value = "";
      setPlaceholder();
      listDesc.style.display = source.Description ? "block" : "none";
      if (source.Description) listDesc.innerHTML = source.Description;
      allGames = source.games || [];
      filterSortGames();
    }

    // ── Game Player (FROGIEE.ONE: fetch HTML then write to iframe) ────────
    async function playGame(url, gameName) {
      if (!url) return;

      // External absolute URLs open in new tab (mirrors FROGIEE.ONE)
      if (url.startsWith("http") && !url.startsWith(HTML_URL)) {
        window.open(url, "_blank");
        return;
      }

      gameOverlay.style.display = "block";
      void gameOverlay.offsetWidth;
      loadingMsg.textContent = "LOADING..";
      loadingMsg.classList.remove("fade-slide-out", "fade-slide-in");
      iframe.src = "about:blank";
      iframe.style.display = "none";
      btnPanel.style.display = "none";
      loadingCont.style.display = "block";
      loadingCont.classList.remove("fade-out");
      requestAnimationFrame(() => {
        browserView.classList.add("view-hidden");
        gameOverlay.classList.add("view-active");
      });

      switchTextTimeout = setTimeout(() => animateText("STILL LOADING.."), 4000);

      try {
        // FROGIEE.ONE pattern: fetch the HTML with cache-bust, write into iframe
        const res  = await fetch(url + "?t=" + Date.now());
        const html = await res.text();
        clearTimeout(switchTextTimeout);
        const doc = iframe.contentDocument || iframe.contentWindow.document;
        doc.open();
        doc.write(html);
        doc.close();
        finishLoading();
      } catch (err) {
        // Fallback: set src directly
        clearTimeout(switchTextTimeout);
        switchTextTimeout = setTimeout(() => animateText("STILL LOADING.."), 4000);
        iframe.onload = () => { clearTimeout(switchTextTimeout); finishLoading(); };
        iframe.src = url;
      }
    }

    function exitGame() {
      gameOverlay.classList.remove("view-active");
      iframe.src = "about:blank";
      iframe.style.display = "none";
      iframe.style.opacity = "0";
      btnPanel.style.display = "none";
      loadingCont.style.display = "none";
      clearTimeout(switchTextTimeout);
      requestAnimationFrame(() => {
        browserView.classList.remove("view-hidden");
        setTimeout(() => { gameOverlay.style.display = "none"; }, 300);
      });
    }

    function finishLoading() {
      loadingCont.classList.add("fade-out");
      loadingCont.addEventListener("animationend", () => {
        loadingCont.style.display = "none";
        iframe.style.display = "block";
        btnPanel.style.display = "flex";
        iframe.style.opacity = 1;
        iframe.focus();
      }, { once: true });
    }

    function animateText(text) {
      loadingMsg.classList.remove("fade-slide-in");
      loadingMsg.classList.add("fade-slide-out");
      loadingMsg.addEventListener("animationend", () => {
        loadingMsg.textContent = text;
        loadingMsg.classList.remove("fade-slide-out");
        loadingMsg.classList.add("fade-slide-in");
      }, { once: true });
    }

    // ── Dropdown Helpers ──────────────────────────────────────────────────
    function closeAllDropdowns() {
      dropdowns.forEach(w => {
        w.classList.remove("open");
        const chev = w.querySelector(".ri-arrow-up-s-line");
        if (chev) { chev.classList.replace("ri-arrow-up-s-line","ri-arrow-down-s-line"); }
      });
      backdrop.classList.remove("active");
    }

    // ── Init ──────────────────────────────────────────────────────────────
    function initSource() {
      srcContainer.innerHTML = "";
      const col = document.createElement("div");
      col.className = "dropdown-column";
      srcContainer.appendChild(col);

      GAME_LISTS.forEach((src, i) => {
        const opt = document.createElement("div");
        opt.className = "option";
        opt.dataset.index = i;
        opt.innerHTML = `<i class="${src.Icon || "ri-file-line"}"></i>${src.Name}`;
        col.appendChild(opt);
      });

      if (GAME_LISTS.length) loadSource(GAME_LISTS[0]);
    }

    function init() {
      setupObservers();
      gridLoading.classList.add("visible");
      fetchGames();
    }

    // ── Event Listeners ───────────────────────────────────────────────────
    input.addEventListener("input", runSearchDebounced);

    globalBtn.addEventListener("click", () => {
      isGlobalSearch = !isGlobalSearch;
      globalBtn.classList.toggle("active", isGlobalSearch);
      srcWrapper.classList.toggle("searching-mode", isGlobalSearch);
      grid.classList.add("fade-games");
      setTimeout(() => {
        clearGrid();
        setPlaceholder();
        if (!isGlobalSearch) loadSource(currentSource);
        input.focus();
        grid.classList.remove("fade-games");
      }, 350);
    });

    filterIcon.addEventListener("click", e => {
      e.stopPropagation();
      const opening = !filterWrapper.classList.contains("open");
      closeAllDropdowns();
      if (opening) { filterWrapper.classList.add("open"); backdrop.classList.add("active"); }
    });

    dropdowns.forEach(wrapper => {
      const menu = wrapper.querySelector(".dropdown-menu");
      const opts = wrapper.querySelector(".dropdown-options");

      if (menu) {
        menu.addEventListener("click", e => {
          if (wrapper.classList.contains("searching-mode")) return;
          e.stopPropagation();
          const opening = !wrapper.classList.contains("open");
          closeAllDropdowns();
          if (opening) {
            wrapper.classList.add("open");
            backdrop.classList.add("active");
            const chev = menu.querySelector(".ri-arrow-down-s-line");
            if (chev) chev.classList.replace("ri-arrow-down-s-line","ri-arrow-up-s-line");
          }
        });
      }

      opts.addEventListener("click", e => {
        const opt = e.target.closest(".option");
        if (!opt) return;
        if (wrapper === srcWrapper) {
          const src = GAME_LISTS[opt.dataset.index];
          if (src && src !== currentSource) loadSource(src);
        } else if (wrapper === filterWrapper) {
          const val = opt.dataset.value;
          if (currentFilter !== val) { currentFilter = val; filterSortGames(); }
        }
        closeAllDropdowns();
      });
    });

    document.addEventListener("click", e => {
      if (!e.target.closest(".dropdown-wrapper") && !e.target.closest(".search-bar")) closeAllDropdowns();
    });

    document.addEventListener("mousedown", e => {
      if (gameOverlay.classList.contains("view-active") && !e.target.closest("#button-panel"))
        setTimeout(() => iframe.focus(), 10);
    });

    fullscreenBtn.addEventListener("click", () => {
      if (iframe.requestFullscreen) iframe.requestFullscreen();
      else if (iframe.webkitRequestFullscreen) iframe.webkitRequestFullscreen();
      setTimeout(() => iframe.focus(), 100);
    });

    backBtn.addEventListener("click", exitGame);
    backdrop.addEventListener("click", closeAllDropdowns);
    grid.addEventListener("scroll", handleScrollMasks);
    new ResizeObserver(handleScrollMasks).observe(grid);

    init();
  </script>
</body>
</html>
